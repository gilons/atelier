{
  "name": "atelier-workspace",
  "version": "0.0.1",
  "private": true,
  "description": "Atelier — a planning companion for the spec-driven era",
  "homepage": "https://github.com/gilons/atelier",
  "repository": {
    "type": "git",
    "url": "https://github.com/gilons/atelier.git"
  },
  "bugs": {
    "url": "https://github.com/gilons/atelier/issues"
  },
  "workspaces": [
    "packages/cli",
    "packages/core",
    "packages/adapters/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean && rm -rf packages/*/dist packages/adapters/*/dist",
    "test": "node --test packages/*/tests/**/*.test.js packages/adapters/*/tests/**/*.test.js",
    "test:core": "node --test packages/core/tests/**/*.test.js",
    "test:cli": "node --test packages/cli/tests/**/*.test.js",
    "atelier": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "gilons",
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
