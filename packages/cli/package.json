{
  "name": "@atelier/cli",
  "version": "0.0.1",
  "description": "Atelier CLI — the planning companion.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "atelier": "./dist/index.js"
  },
  "files": [
    "dist",
    "macos-helper",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build && npm run build:macos-helper",
    "build:macos-helper": "./scripts/compile-macos-helper.sh",
    "clean": "tsc --build --clean && rm -rf dist",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "@atelier/core": "0.0.1"
  },
  "license": "MIT",
  "author": "gilons",
  "repository": {
    "type": "git",
    "url": "https://github.com/gilons/atelier.git",
    "directory": "packages/cli"
  }
}
